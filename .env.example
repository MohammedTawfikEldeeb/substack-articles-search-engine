# =========================
# Supabase
# =========================
SUPABASE_DB__TABLE_NAME=substack_articles
SUPABASE_DB__HOST=your-supabase-host
SUPABASE_DB__NAME=postgres
SUPABASE_DB__USER=your-supabase-user
SUPABASE_DB__PASSWORD=your-supabase-password
SUPABASE_DB__PORT=6543

# =========================
# RSS
# =========================
RSS__DEFAULT_START_DATE=2025-09-15
RSS__BATCH_SIZE=30

# =========================
# Qdrant
# =========================
QDRANT__API_KEY=your-qdrant-api-key
QDRANT__URL=https://your-qdrant-instance.cloud.qdrant.io
QDRANT__COLLECTION_NAME=substack_collection
QDRANT__DENSE_MODEL_NAME=BAAI/bge-base-en-v1.5
QDRANT__SPARSE_MODEL_NAME=Qdrant/bm25
QDRANT__VECTOR_DIM=768
QDRANT__ARTICLE_BATCH_SIZE=5
QDRANT__SPARSE_BATCH_SIZE=32
QDRANT__EMBED_BATCH_SIZE=50
QDRANT__UPSERT_BATCH_SIZE=100
QDRANT__MAX_CONCURRENT=3

# Semantic cache
QDRANT__SEMANTIC_CACHE_COLLECTION_NAME=semantic_cache
QDRANT__SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
QDRANT__SEMANTIC_CACHE_TTL_SECONDS=3600
QDRANT__SEMANTIC_CACHE_CONTENT_VERSION=v1

# =========================
# Text splitter
# =========================
TEXT_SPLITTER__CHUNK_SIZE=800
TEXT_SPLITTER__CHUNK_OVERLAP=200
TS__CHUNK_SIZE=800
TS__CHUNK_OVERLAP=200

# =========================
# Prefect
# =========================
PREFECT__API_KEY=your-prefect-api-key
PREFECT__WORKSPACE=default
PREFECT__API_URL=https://api.prefect.cloud/api/accounts/<account-id>/workspaces/<workspace-id>

# =========================
# Hugging Face
# =========================
HUGGING_FACE__API_KEY=your-hugging-face-api-key
HUGGING_FACE__MODEL=BAAI/bge-base-en-v1.5

# =========================
# OpenRouter
# =========================
OPENROUTER__API_KEY=your-openrouter-api-key
OPENROUTER__API_URL=https://openrouter.ai/api/v1

# =========================
# Opik
# =========================
OPIK__API_KEY=your-opik-api-key
OPIK__PROJECT_NAME=substack-pipeline

# =========================
# API / CORS
# =========================
ALLOWED_ORIGINS=http://localhost:5173

# =========================
# Frontend
# =========================
VITE_API_BASE=http://localhost:8080
